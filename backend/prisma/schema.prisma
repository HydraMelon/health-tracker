generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  sessions         Session[]
  muscleGroups     MuscleGroup[]
}

model MuscleGroup {
  id     Int    @id @default(autoincrement())
  name   String
  userId Int

  user                User                  @relation(fields: [userId], references: [id])
  exerciseDefinitions ExerciseDefinition[]
  sessions            Session[]
}

model ExerciseDefinition {
  id            Int    @id @default(autoincrement())
  name          String
  muscleGroupId Int

  muscleGroup      MuscleGroup       @relation(fields: [muscleGroupId], references: [id])
  sessionExercises SessionExercise[]
}

model Session {
  id            Int      @id @default(autoincrement())
  date          DateTime
  userId        Int
  muscleGroupId Int

  user            User              @relation(fields: [userId], references: [id])
  muscleGroup     MuscleGroup       @relation(fields: [muscleGroupId], references: [id])
  sessionExercises SessionExercise[]
}

model SessionExercise {
  id                   Int @id @default(autoincrement())
  sessionId            Int
  exerciseDefinitionId Int

  session             Session            @relation(fields: [sessionId], references: [id])
  exerciseDefinition  ExerciseDefinition @relation(fields: [exerciseDefinitionId], references: [id])
  sets                Set[]
}

model Set {
  id                Int @id @default(autoincrement())
  sessionExerciseId Int
  setNumber         Int
  weight            Float
  reps              Int

  sessionExercise SessionExercise @relation(fields: [sessionExerciseId], references: [id])
}